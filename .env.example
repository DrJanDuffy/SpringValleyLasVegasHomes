# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
# Runtime: set in Vercel Project Settings for /api/chat and /api/generate-property-description (not required for next build)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Environment
NODE_ENV=development

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://www.springvalleylasvegashomes.com

# Google Search Console — HTML tag verification (optional). Paste the content value from GSC → Settings → Ownership verification.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Maps JavaScript API (optional) — enables the interactive map on /las-vegas-zip-code-map.
# In Google Cloud: enable "Maps JavaScript API" for your project, create an API key, restrict by HTTP referrer
# (e.g. https://www.springvalleylasvegashomes.com/* and http://localhost:3000/* for local dev).
# Copy the key to Vercel → Settings → Environment Variables (Production/Preview), then redeploy — NEXT_PUBLIC_* is inlined at build.
# The zip directory list on that page works without a key; only the embedded map requires it.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# RealScout (optional overrides — defaults match Dr. Jan Duffy portal)
# NEXT_PUBLIC_REALSCOUT_PORTAL_URL=https://drjanduffy.realscout.com
# NEXT_PUBLIC_REALSCOUT_AGENT_ID=QWdlbnQtMjI1MDUw
# NEXT_PUBLIC_REALSCOUT_SIMPLE_SEARCH_PLACEHOLDER=Spring Valley, NV
# City-filtered map search (Spring Valley) — deep link on agent portal; update if RealScout geo_id changes
# NEXT_PUBLIC_REALSCOUT_SPRING_VALLEY_MAP_URL=https://drjanduffy.realscout.com/homesearch/map?geo_type=city&geo_id=3268585

# Homebot valuation iframe on /home-valuation (paste embed URL from Homebot dashboard)
# NEXT_PUBLIC_HOMEBOT_WIDGET_URL=

# Keeping Current Matters — English blog + RSS by default (same affiliate token as KCM dashboard)
# Override only if you need Spanish: use /es/?a=… and /es/feed?a=… URLs from your KCM account
# NEXT_PUBLIC_KCM_BLOG_EMBED_URL=https://www.simplifyingthemarket.com/?a=YOUR_TOKEN
# NEXT_PUBLIC_KCM_RSS_FEED_URL=https://www.simplifyingthemarket.com/feed?a=YOUR_TOKEN

# Follow Up Boss: copy from .env.fub.example — FUB_API_KEY, FUB_DEFAULT_LEAD_TAG (site-wide CRM tag), webhooks, etc.

# Google Maps Neighborhood Discovery — hosted iframe URL (default: Maps Solutions GCS HTML; must match CSP frame-src storage.googleapis.com)
# NEXT_PUBLIC_NEIGHBORHOOD_DISCOVERY_IFRAME_URL=

# Google 3D Area Explorer — optional self-hosted demo URL for /neighborhood-discovery (must match CSP frame-src)
# NEXT_PUBLIC_GOOGLE_3D_EXPLORER_DEMO_URL=

# Cloudflare Images — delivery URLs: https://imagedelivery.net/<account_hash>/<image_id>/<variant>
# Public hash (not secret). Defaults in code match this project if unset.
# NEXT_PUBLIC_CLOUDFLARE_ACCOUNT_HASH=byE6BTe9lNqo21V57n4aPQ
# After uploading each asset in Cloudflare, set the image ID (optional — site falls back to /public files).
# NEXT_PUBLIC_CF_IMAGE_HEADSHOT_ID=
# NEXT_PUBLIC_CF_IMAGE_HERO_1_ID=
# NEXT_PUBLIC_CF_IMAGE_HERO_2_ID=
# NEXT_PUBLIC_CF_IMAGE_HERO_3_ID=
# NEXT_PUBLIC_CF_IMAGE_FEATURED_1_ID=
# NEXT_PUBLIC_CF_IMAGE_FEATURED_2_ID=
# NEXT_PUBLIC_CF_IMAGE_FEATURED_3_ID=
# NEXT_PUBLIC_CF_IMAGE_REVIEW_1_ID=
# NEXT_PUBLIC_CF_IMAGE_REVIEW_2_ID=
# NEXT_PUBLIC_CF_IMAGE_REVIEW_3_ID=
# NEXT_PUBLIC_CF_IMAGE_LISTING_PLACEHOLDER_ID=
# Favicon (SERP / browser) — defaults in lib/site-media.ts if unset (Cloudflare Images w=800)
# NEXT_PUBLIC_CF_IMAGE_FAVICON_ID=
# NEXT_PUBLIC_CF_VARIANT_FAVICON=w=800
# NEXT_PUBLIC_CF_VARIANT_FAVICON_APPLE=w=180
# Optional variant names (must exist in Cloudflare dashboard): public | hero | avatar
# NEXT_PUBLIC_CF_VARIANT_PUBLIC=public
# NEXT_PUBLIC_CF_VARIANT_HERO=public
# NEXT_PUBLIC_CF_VARIANT_AVATAR=public
