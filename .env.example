# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
# Runtime: set in Vercel Project Settings for /api/chat and /api/generate-property-description (not required for next build)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Next.js Environment
NODE_ENV=development

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://heyberkshire.com
